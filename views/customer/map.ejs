
<div style="padding: 0 20px 16px;">
  <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">
    <i class="fas fa-map-marker-alt" style="color: var(--accent);"></i> Tìm trạm sạc
  </h3>
  <div class="search-bar-input">
    <i class="fas fa-search"></i>
    <input type="text" placeholder="Tìm theo tên hoặc địa chỉ..." id="searchStationInput" onkeyup="searchStations()">
  </div>
</div>

<div class="map-container">
  <div id="map"></div>
</div>

<!-- Station List Below Map -->
<div style="padding: 16px 20px 0;">
  <div class="section-title" style="padding: 0; margin-bottom: 12px;">
    <h3>Kết quả</h3>
    <span id="stationCount" style="font-size: 13px; color: var(--text-muted);">0 trạm</span>
  </div>
  <div class="station-list" id="stationResults" style="padding: 0;"></div>
</div>

<script>
  const stationsData = <%- stations %>;
</script>
<script src="/js/map.js"></script>
