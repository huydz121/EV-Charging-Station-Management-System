<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Xác thực OTP | EV Charge</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/customer.css">
</head>
<body>
  <div class="login-page">
    <div class="login-container">
      <div class="login-logo">
        <div class="login-logo-icon">⚡</div>
        <h1>EV <span>Charge</span></h1>
      </div>

      <div class="login-card">
        <div class="text-center">
          <h2>Xác thực OTP</h2>
          <p class="login-subtitle">Nhập mã 6 số đã được gửi đến email của bạn</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="ev-alert ev-alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <%= error %>
          </div>
        <% } %>

        <form action="/auth/verify-otp" method="POST" class="login-form">
          <input type="hidden" name="email" value="<%= email %>">
          <input type="hidden" name="type" value="<%= type %>">
          
          <div class="form-group">
            <i class="fas fa-key input-icon"></i>
            <input type="text" name="otp" class="ev-input" placeholder="Mã OTP" required maxlength="6">
          </div>
          <button type="submit" class="btn-ev btn-ev-primary">
            <i class="fas fa-check-circle"></i> Xác thực
          </button>
        </form>

        <div class="login-footer">
          <a href="/auth/login"><i class="fas fa-arrow-left"></i> Quay lại đăng nhập</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
