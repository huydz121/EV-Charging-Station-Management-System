<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quên mật khẩu | EV Charge</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/customer.css">
</head>
<body>
  <div class="login-page">
    <div class="login-container">
      <div class="login-logo">
        <div class="login-logo-icon">⚡</div>
        <h1>EV <span>Charge</span></h1>
      </div>

      <div class="login-card">
        <div class="text-center">
          <h2>Quên mật khẩu</h2>
          <p class="login-subtitle">Nhập email để nhận mã OTP khôi phục</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="ev-alert ev-alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            <%= error %>
          </div>
        <% } %>

        <form action="/auth/forgot-password" method="POST" class="login-form">
          <div class="form-group">
            <i class="fas fa-envelope input-icon"></i>
            <input type="email" name="email" class="ev-input" placeholder="Email của bạn" required>
          </div>
          <button type="submit" class="btn-ev btn-ev-primary">
            <i class="fas fa-paper-plane"></i> Gửi mã OTP
          </button>
        </form>

        <div class="login-footer">
          <a href="/auth/login"><i class="fas fa-arrow-left"></i> Quay lại đăng nhập</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
